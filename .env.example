# Copy to .env.local and fill in values for local dev. Never commit .env.local.

# Buzzmart backend (Django REST API)
NEXT_PUBLIC_BASE_URI=http://127.0.0.1:8000/api

# Appwrite (used for product / dispatcher image uploads). Optional for boot,
# required for image upload flows.
NEXT_PUBLIC_APPWRITE_BASE_URI=
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
NEXT_PUBLIC_APPWRITE_BUCKET_ID=

# Google Maps autocomplete on the setup wizard
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Flutterwave — PUBLIC key is used client-side to list banks, SECRET key is
# used only by the server-side route at app/api/resolve to verify accounts.
# The SECRET key MUST NOT have a NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=

# Public base URL of the Next.js frontend. Used to build absolute share-link
# URLs (e.g. for OG meta `og:url` and copy-link buttons).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
